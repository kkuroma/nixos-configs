// Colors generated by noctalia at runtime — loaded as a separate file so
// theme changes take effect without rebuilding HM config.
// home/niri.nix creates an empty fallback so niri starts before first noctalia run.
include "noctalia.kdl"

window-rule {
    geometry-corner-radius 6
    clip-to-geometry true
}

debug {
    honor-xdg-activation-with-invalid-serial
}

layer-rule {
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}
